# Required for server startup.
# Use a unique secret per environment. It must be at least 32 bytes when encoded as UTF-8.
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes

# Required for production database connection.
# When DB_URL is absent the server falls back to an embedded PostgreSQL instance (dev/test only).
DB_URL=jdbc:postgresql://localhost:5432/auction_db
DB_USER=postgres
DB_PASSWORD=replace-with-your-db-password
